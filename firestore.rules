rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: usuário autenticado ────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // ─── Clientes ────────────────────────────────────────────────
    match /clientes/{clienteId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Equipamentos ────────────────────────────────────────────
    match /equipamentos/{equipamentoId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Prestadores ─────────────────────────────────────────────
    match /prestadores/{prestadorId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Ordens de Serviço ───────────────────────────────────────
    match /ordens/{ordemId} {
      allow read, write: if isAuthenticated();
    }

    // ─── Regra de fallback: nega tudo que não foi explicitado ─────
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
